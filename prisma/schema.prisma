generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/**
 * ================= ENUMS =================
 */

enum NoticeTargetRole {
  ALL
  PARENT
  TEACHER
  STUDENT
}

enum EventType {
  EXAM
  HOLIDAY
  SPORTS
  CULTURAL
  MEETING
  OTHER
}

enum BookIssueStatus {
  ISSUED
  RETURNED
  OVERDUE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum FeeType {
  TUITION
  TRANSPORT
  LIBRARY
  SPORTS
  LAB
  OTHER
}

enum FeeFrequency {
  ONCE
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum PaymentMode {
  CASH
  RAZORPAY
  CHEQUE
}

enum FineType {
  LIBRARY
  DAMAGE
  LATE
  UNIFORM
  OTHER
}

enum AdmissionStatus {
  PENDING
  CALLED
  ENROLLED
  REJECTED
  NEW
  CONTACTED
  CONVERTED
}

enum StudentStatus {
  ACTIVE
  TC_ISSUED
  DETAINED
}

/**
 * ================= AUTH =================
 */

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  isActive Boolean @default(true)

  roles    UserRole[]
  sessions Session[]

  student Student?
  staff   Staff?
  parent  Parent?

  // CMS relations
  notices   Notice[]
  events    Event[]
  resources Resource[]
  galleries Gallery[]
  tcRecords TCRecord[] @relation("Approver")
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id   String @id @default(cuid())
  name String @unique

  users       UserRole[]
  permissions RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Permission {
  id   String @id @default(cuid())
  name String @unique

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * ================= ACADEMIC CORE =================
 */

model AcademicYear {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime

  enrollments Enrollment[]
  attendance  Attendance[]
  fees        FeeStructure[]
  exams       Exam[]
  toppers     Topper[]

  createdAt DateTime @default(now())
}

model Class {
  id   String @id @default(cuid())
  name String

  sections    Section[]
  fees        FeeStructure[]
  enquiries   AdmissionEnquiry[]
  exams       Exam[]
  subjects    Subject[]
  attendances Attendance[]

  createdAt DateTime @default(now())
}

model Section {
  id      String @id @default(cuid())
  name    String
  classId String

  class Class @relation(fields: [classId], references: [id])

  enrollments        Enrollment[]
  staffSubjects      StaffSubject[]
  homeworks          Homework[]
  curriculumProgress CurriculumProgress[]

  createdAt DateTime @default(now())
}

/**
 * ================= PEOPLE =================
 */

model Student {
  id          String   @id @default(cuid())
  userId      String?  @unique
  firstName   String
  lastName    String
  dob         DateTime
  gender      String
  admissionNo String   @unique

  rollNo      String?
  photo       String?
  parentName  String?
  parentPhone String?
  address     String?
  aadharNo    String?
  status      StudentStatus @default(ACTIVE)

  enrollments Enrollment[]
  parents     StudentParent[]

  attendance          Attendance[]
  fees                FeeRecord[]
  tcRecords           TCRecord[]
  homeworkSubmissions HomeworkSubmission[]
  examResults         ExamResult[]
  remarks             TeacherRemark[]
  fines               Fine[]
  bookIssues          BookIssue[]
  studentRoute        StudentRoute?
  toppers             Topper[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Parent {
  id     String @id @default(cuid())
  userId String @unique
  name   String
  phone  String

  students StudentParent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model StudentParent {
  studentId String
  parentId  String

  student Student @relation(fields: [studentId], references: [id])
  parent  Parent  @relation(fields: [parentId], references: [id])

  @@id([studentId, parentId])
}

model Staff {
  id     String @id @default(cuid())
  userId String @unique
  name   String

  empCode       String?   @unique
  designation   String?
  photo         String?
  dateOfJoining DateTime?
  qualification String?
  displayOrder  Int       @default(0)
  isPublic      Boolean   @default(true)
  isActive      Boolean   @default(true)

  subjects       StaffSubject[]
  taughtSubjects Subject[]          @relation("TeacherSubject")
  remarks        TeacherRemark[]
  enquiries      AdmissionEnquiry[]
  homeworks      Homework[]
  tcRecords      TCRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

/**
 * ================= SUBJECT SYSTEM =================
 */

model Subject {
  id           String  @id @default(cuid())
  name         String
  code         String?
  maxMarks     Float?
  passingMarks Float?

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  teacherId String?
  teacher   Staff?  @relation("TeacherSubject", fields: [teacherId], references: [id])

  staff              StaffSubject[]
  homeworks          Homework[]
  examResults        ExamResult[]
  curriculumProgress CurriculumProgress[]
}

model StaffSubject {
  staffId   String
  subjectId String
  sectionId String

  staff   Staff   @relation(fields: [staffId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@id([staffId, subjectId, sectionId])
}

/**
 * ================= ENROLLMENT =================
 */

model Enrollment {
  id        String @id @default(cuid())
  studentId String
  sectionId String
  yearId    String

  student Student      @relation(fields: [studentId], references: [id])
  section Section      @relation(fields: [sectionId], references: [id])
  year    AcademicYear @relation(fields: [yearId], references: [id])

  @@unique([studentId, yearId])
}

/**
 * ================= ATTENDANCE =================
 */

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  date       DateTime
  status     AttendanceStatus
  reason     String?
  markedById String?

  yearId  String
  classId String?

  student Student      @relation(fields: [studentId], references: [id])
  year    AcademicYear @relation(fields: [yearId], references: [id])
  class   Class?       @relation(fields: [classId], references: [id])

  @@unique([studentId, date])
  @@index([yearId])
}

/**
 * ================= FEES =================
 */

model FeeStructure {
  id          String       @id @default(cuid())
  name        String?
  feeType     FeeType      @default(OTHER)
  amount      Float
  dueDate     DateTime?
  isRecurring Boolean      @default(false)
  frequency   FeeFrequency @default(ONCE)

  classId String
  yearId  String

  class Class        @relation(fields: [classId], references: [id])
  year  AcademicYear @relation(fields: [yearId], references: [id])

  records FeeRecord[]
}

model FeeRecord {
  id            String       @id @default(cuid())
  studentId     String
  structureId   String
  amountDue     Float?
  amountPaid    Float        @default(0)
  dueDate       DateTime?
  paidDate      DateTime?
  paymentMode   PaymentMode?
  transactionId String?
  receiptNo     String?
  status        FeeStatus    @default(PENDING)

  student   Student      @relation(fields: [studentId], references: [id])
  structure FeeStructure @relation(fields: [structureId], references: [id])

  payments Payment[]

  @@index([studentId])
}

model Payment {
  id     String   @id @default(cuid())
  feeId  String
  amount Float
  method String
  paidAt DateTime

  fee FeeRecord @relation(fields: [feeId], references: [id])
}

/**
 * ================= CMS =================
 */

model Notice {
  id          String           @id @default(cuid())
  titleEn     String
  titleHi     String?
  contentEn   String
  contentHi   String?
  slug        String           @unique
  published   Boolean          @default(false)
  isPinned    Boolean          @default(false)
  isPublic    Boolean          @default(false)
  targetRole  NoticeTargetRole @default(ALL)
  targetClass String?
  scheduledAt DateTime?
  publishedAt DateTime         @default(now())

  createdBy String
  author    User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Event {
  id            String    @id @default(cuid())
  titleEn       String
  titleHi       String?
  descriptionEn String
  descriptionHi String?
  date          DateTime
  slug          String    @unique
  published     Boolean   @default(false)
  photo         String?
  eventType     EventType @default(OTHER)
  targetClass   String?

  createdBy String
  author    User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Gallery {
  id          String   @id @default(cuid())
  titleEn     String
  titleHi     String?
  description String?
  published   Boolean  @default(false)
  coverImage  String?
  eventDate   DateTime @default(now())

  createdBy String
  author    User   @relation(fields: [createdBy], references: [id])

  media Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String @id @default(cuid())
  url       String
  galleryId String

  gallery Gallery @relation(fields: [galleryId], references: [id])
}

model Resource {
  id        String  @id @default(cuid())
  title     String
  fileUrl   String
  type      String?
  slug      String  @unique
  published Boolean @default(false)

  createdBy String
  author    User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Added back Slider table from the plan
model Slider {
  id        String  @id @default(cuid())
  title     String?
  imageUrl  String
  link      String?
  order     Int     @default(0)
  published Boolean @default(true)

  createdAt DateTime @default(now())
}

// Added back Topper table from the plan
model Topper {
  id         String  @id @default(cuid())
  name       String
  class      String
  year       String
  percentage Float
  imageUrl   String?

  createdAt      DateTime      @default(now())
  AcademicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  academicYearId String?
  Student        Student?      @relation(fields: [studentId], references: [id])
  studentId      String?
}

/**
 * ================= ADMISSIONS =================
 */

model Admission {
  id          String          @id @default(cuid())
  studentName String
  parentName  String
  email       String
  phone       String
  grade       String
  status      AdmissionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdmissionEnquiry {
  id          String          @id @default(cuid())
  name        String
  phone       String
  parentName  String?
  parentEmail String?
  notes       String?
  classId     String
  status      AdmissionStatus

  handledById String?
  handledBy   Staff?  @relation(fields: [handledById], references: [id])

  class Class @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * ================= TC =================
 */

model TCRecord {
  id             String    @id @default(cuid())
  studentId      String
  certificateNo  String    @unique
  reason         String
  fileUrl        String
  issuedAt       DateTime
  approvedBy     String
  dateOfLeaving  DateTime?
  classAtLeaving String?
  conductGrade   String?
  issuedById     String?

  student  Student @relation(fields: [studentId], references: [id])
  approver User    @relation("Approver", fields: [approvedBy], references: [id])
  issuedBy Staff?  @relation(fields: [issuedById], references: [id])
}

/**
 * ================= PORTAL ACADEMICS =================
 */

enum HomeworkStatus {
  PENDING
  SUBMITTED
  GRADED
}

enum RemarkType {
  POSITIVE
  NEEDS_IMPROVEMENT
  WARNING
  GENERAL
}

model Homework {
  id            String   @id @default(cuid())
  title         String
  description   String
  dueDate       DateTime
  subjectId     String
  sectionId     String
  attachmentUrl String?
  postedAt      DateTime @default(now())
  postedById    String?
  createdAt     DateTime @default(now())

  subject  Subject @relation(fields: [subjectId], references: [id])
  section  Section @relation(fields: [sectionId], references: [id])
  postedBy Staff?  @relation(fields: [postedById], references: [id])

  submissions HomeworkSubmission[]
}

model HomeworkSubmission {
  id          String         @id @default(cuid())
  homeworkId  String
  studentId   String
  status      HomeworkStatus @default(PENDING)
  grade       String?
  feedback    String?
  submittedAt DateTime?

  homework Homework @relation(fields: [homeworkId], references: [id])
  student  Student  @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
}

model Exam {
  id          String    @id @default(cuid())
  title       String
  term        String?
  date        DateTime
  startDate   DateTime?
  endDate     DateTime?
  isPublished Boolean   @default(false)
  yearId      String
  classId     String

  year  AcademicYear @relation(fields: [yearId], references: [id])
  class Class        @relation(fields: [classId], references: [id])

  results ExamResult[]
}

model ExamResult {
  id            String   @id @default(cuid())
  examId        String
  studentId     String
  subjectId     String
  marksObtained Float
  maxMarks      Float
  grade         String?
  remarks       String?
  enteredById   String?
  updatedAt     DateTime @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([examId, studentId, subjectId])
}

model TeacherRemark {
  id        String     @id @default(cuid())
  studentId String
  staffId   String
  content   String
  type      RemarkType @default(GENERAL)
  date      DateTime   @default(now())

  student Student @relation(fields: [studentId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])
}

model CurriculumProgress {
  id                String   @id @default(cuid())
  subjectId         String
  sectionId         String
  chaptersTotal     Int
  chaptersCompleted Int
  updatedAt         DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([subjectId, sectionId])
}

/**
 * ================= FINES =================
 */

model Fine {
  id          String    @id @default(cuid())
  fineType    FineType
  amount      Float
  reason      String?
  imposedById String
  imposedAt   DateTime  @default(now())
  isPaid      Boolean   @default(false)
  paidAt      DateTime?

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

/**
 * ================= LIBRARY =================
 */

model Book {
  id            String  @id @default(cuid())
  title         String
  author        String?
  isbn          String?
  copies        Int     @default(1)
  shelfLocation String?

  issues BookIssue[]
}

model BookIssue {
  id         String          @id @default(cuid())
  issueDate  DateTime        @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     BookIssueStatus @default(ISSUED)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

/**
 * ================= TRANSPORT =================
 */

model Route {
  id            String  @id @default(cuid())
  name          String
  stops         Json
  driverName    String?
  vehicleNumber String?
  feeAmount     Float

  studentRoutes StudentRoute[]
}

model StudentRoute {
  id         String @id @default(cuid())
  pickupStop String
  pickupTime String

  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id])

  routeId String
  route   Route  @relation(fields: [routeId], references: [id])
}

/**
 * ================= SYSTEM =================
 */

model Download {
  id         String   @id @default(cuid())
  title      String
  fileUrl    String
  category   String
  isPublic   Boolean  @default(true)
  uploadedAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  targetModel String
  targetId    String
  oldValue    Json?
  newValue    Json?
  timestamp   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
